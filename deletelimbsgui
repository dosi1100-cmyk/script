local dragging = false
local dragStartPos = nil
local frameStartPos = nil

local function onDragBegan(inputPos)
    dragging = true
    dragStartPos = inputPos
    frameStartPos = mainFrame.Position
end

local function onDragChanged(inputPos)
    if not dragging then return end
    local delta = inputPos - dragStartPos
    local newX = frameStartPos.X.Offset + delta.X
    local newY = frameStartPos.Y.Offset + delta.Y
    mainFrame.Position = UDim2.new(frameStartPos.X.Scale, newX, frameStartPos.Y.Scale, newY)
end

local function onDragEnded()
    dragging = false
end

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        onDragBegan(Vector2.new(input.Position.X, input.Position.Y))
    end
end)

titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        onDragChanged(Vector2.new(input.Position.X, input.Position.Y))
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        onDragEnded()
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
