local function setRagdoll(state)
    local char = plr.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local ragdollRemote = ReplicatedStorage:FindFirstChild("CharacterEvents")
            and ReplicatedStorage.CharacterEvents:FindFirstChild("RagdollRemote")
        if hrp and ragdollRemote then
            ragdollRemote:FireServer(hrp, state and 1 or 0)
        end
    end
end

local function deleteParts(config)
    local char = plr.Character
    if not char then warn("캐릭터를 찾을 수 없습니다.") return end

    local partNames = {
        RightArm = "Right Arm",
        LeftArm  = "Left Arm",
        RightLeg = "Right Leg",
        LeftLeg  = "Left Leg",
    }

    local targets = {}
    for key, shouldDelete in pairs(config) do
        if shouldDelete then
            local part = char:FindFirstChild(partNames[key])
            if part then table.insert(targets, part) end
        end
    end

    if #targets == 0 then warn("삭제할 부위를 찾을 수 없습니다.") return end

    setRagdoll(true)
    task.wait(0.3)

    for _, part in ipairs(targets) do
        if part then part.CFrame = CFrame.new(0, -99999, 0) end
    end

    task.wait(0.1)

    local torso = char:FindFirstChild("Torso")
    local setNetworkOwnerRemote = ReplicatedStorage:FindFirstChild("GrabEvents")
        and ReplicatedStorage.GrabEvents:FindFirstChild("SetNetworkOwner")
    if torso and setNetworkOwnerRemote then
        setNetworkOwnerRemote:FireServer(torso, torso.CFrame)
    end
end

